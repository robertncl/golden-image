# syntax=docker/dockerfile:1
# Debian 12 (Bookworm) LTS — CIS-hardened base image.
# Hardened to CIS Docker Benchmark v1.7.0 (section 4) + CIS Docker-Image checks.
# Base pinned by tag AND digest (CIS 4.2 / 4.5 — trusted, immutable base).
FROM debian:12-slim@sha256:60eac759739651111db372c07be67863818726f754804b8707c90979bda511df

ARG BUILD_DATE
ARG VCS_REF
ARG VERSION=1.0.0

LABEL maintainer="Golden Image Build System" \
      org.opencontainers.image.created="${BUILD_DATE}" \
      org.opencontainers.image.version="${VERSION}" \
      org.opencontainers.image.revision="${VCS_REF}" \
      org.opencontainers.image.vendor="Golden Image Build System" \
      org.opencontainers.image.title="Debian 12 (Bookworm) CIS-Hardened Base" \
      org.opencontainers.image.description="Debian 12 base hardened to CIS Docker Benchmark v1.7.0" \
      org.opencontainers.image.source="https://github.com/your-org/golden-image" \
      org.opencontainers.image.licenses="MIT" \
      io.golden-image.cis.benchmark="CIS Docker Benchmark v1.7.0"

ENV DEBIAN_FRONTEND=noninteractive

# Patch to latest, install only init + CA certs, then harden — single layer.
# update+install combined (CIS 4.7); hardening script purges apt caches/docs.
COPY scripts/container/harden-debian.sh /tmp/harden.sh
RUN apt-get update && \
    apt-get upgrade -y --no-install-recommends && \
    apt-get install -y --no-install-recommends ca-certificates tini && \
    chmod 0755 /tmp/harden.sh && /tmp/harden.sh && \
    rm -f /tmp/harden.sh && \
    apt-get clean && rm -rf /var/lib/apt/lists/*

WORKDIR /app

# Run as the non-root user created by the hardening script (CIS 4.1).
USER appuser

# CIS 4.6 / CIS-DI-0006 — define a HEALTHCHECK.
HEALTHCHECK --interval=30s --timeout=3s --start-period=5s --retries=3 \
    CMD test -r /etc/os-release || exit 1

ENTRYPOINT ["/usr/bin/tini", "--"]
CMD ["/bin/bash"]
