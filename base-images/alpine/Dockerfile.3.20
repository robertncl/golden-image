# syntax=docker/dockerfile:1
# Alpine Linux 3.20 LTS — CIS-hardened base image.
# Hardened to CIS Docker Benchmark v1.7.0 (section 4) + CIS Docker-Image checks.
# Base pinned by tag AND digest (CIS 4.2 / 4.5 — trusted, immutable base).
FROM alpine:3.20@sha256:d9e853e87e55526f6b2917df91a2115c36dd7c696a35be12163d44e6e2a4b6bc

ARG BUILD_DATE
ARG VCS_REF
ARG VERSION=1.0.0

LABEL maintainer="Golden Image Build System" \
      org.opencontainers.image.created="${BUILD_DATE}" \
      org.opencontainers.image.version="${VERSION}" \
      org.opencontainers.image.revision="${VCS_REF}" \
      org.opencontainers.image.vendor="Golden Image Build System" \
      org.opencontainers.image.title="Alpine Linux 3.20 CIS-Hardened Base" \
      org.opencontainers.image.description="Alpine 3.20 base hardened to CIS Docker Benchmark v1.7.0" \
      org.opencontainers.image.source="https://github.com/your-org/golden-image" \
      org.opencontainers.image.licenses="MIT" \
      io.golden-image.cis.benchmark="CIS Docker Benchmark v1.7.0"

# Patch to latest, install only init + CA certs, then harden — single layer.
# update+install are combined so a cached `update` can never serve stale
# packages (CIS 4.7); the hardening script purges caches afterwards.
COPY scripts/container/harden-alpine.sh /tmp/harden.sh
RUN apk update && apk upgrade --no-cache && \
    apk add --no-cache ca-certificates tini && \
    chmod 0755 /tmp/harden.sh && /tmp/harden.sh && \
    rm -f /tmp/harden.sh

WORKDIR /app

# Run as the non-root user created by the hardening script (CIS 4.1).
USER appuser

# CIS 4.6 / CIS-DI-0006 — define a HEALTHCHECK.
HEALTHCHECK --interval=30s --timeout=3s --start-period=5s --retries=3 \
    CMD test -r /etc/os-release || exit 1

# tini as PID 1 for correct signal handling / zombie reaping.
ENTRYPOINT ["/sbin/tini", "--"]
CMD ["/bin/sh"]
