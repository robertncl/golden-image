# syntax=docker/dockerfile:1
# RedHat UBI 9 (ubi-minimal) — CIS-hardened base image.
# Hardened to CIS Docker Benchmark v1.7.0 (section 4) + CIS Docker-Image checks.
# Base pinned by tag AND digest (CIS 4.2 / 4.5 — trusted, immutable base).
FROM registry.access.redhat.com/ubi9/ubi-minimal:latest@sha256:44bc70ef6e6ea9a70e353be97f4722e10358d09fbb9494ca943b2a641049690e

ARG BUILD_DATE
ARG VCS_REF
ARG VERSION=1.0.0

LABEL maintainer="Golden Image Build System" \
      org.opencontainers.image.created="${BUILD_DATE}" \
      org.opencontainers.image.version="${VERSION}" \
      org.opencontainers.image.revision="${VCS_REF}" \
      org.opencontainers.image.vendor="Golden Image Build System" \
      org.opencontainers.image.title="RedHat UBI 9 CIS-Hardened Base" \
      org.opencontainers.image.description="UBI 9 minimal base hardened to CIS Docker Benchmark v1.7.0" \
      org.opencontainers.image.source="https://github.com/your-org/golden-image" \
      org.opencontainers.image.licenses="MIT" \
      io.golden-image.cis.benchmark="CIS Docker Benchmark v1.7.0"

# Patch to latest, install CA certs + shadow-utils (for useradd), then harden.
# ubi-minimal has no tini/dumb-init in its repos, so PID-1 reaping is left to
# the orchestrator; this is documented in docs/CIS-COMPLIANCE.md.
COPY scripts/container/harden-redhat.sh /tmp/harden.sh
RUN microdnf -y update && \
    microdnf -y install ca-certificates shadow-utils && \
    microdnf clean all && \
    chmod 0755 /tmp/harden.sh && /tmp/harden.sh && \
    rm -f /tmp/harden.sh

WORKDIR /app

# Run as the non-root user created by the hardening script (CIS 4.1).
USER appuser

# CIS 4.6 / CIS-DI-0006 — define a HEALTHCHECK.
HEALTHCHECK --interval=30s --timeout=3s --start-period=5s --retries=3 \
    CMD test -r /etc/os-release || exit 1

CMD ["/bin/bash"]
