# Platform LTS Version Configuration
# This file defines the supported LTS versions for each platform software
# Add or remove versions as needed by editing this file
# Updated 2026-06-29: bumped to current stable/LTS releases.

# Nginx stable versions
NGINX_VERSIONS="1.26 1.28"

# OpenJDK LTS versions
OPENJDK_VERSIONS="17 21"

# Tomcat versions
TOMCAT_VERSIONS="10.1 11.0"

# Python versions
PYTHON_VERSIONS="3.12 3.13"

# Spring Boot versions
SPRINGBOOT_VERSIONS="3.4 3.5"

# ASP.NET Core versions
ASPNET_VERSIONS="9.0 10.0"

# .NET Runtime versions
DOTNET_VERSIONS="9.0 10.0"

# Default versions (used for platform images when no specific version is specified) — latest stable/LTS
DEFAULT_NGINX_VERSION=1.28
DEFAULT_OPENJDK_VERSION=21
DEFAULT_TOMCAT_VERSION=11.0
DEFAULT_PYTHON_VERSION=3.13
DEFAULT_SPRINGBOOT_VERSION=3.5
DEFAULT_ASPNET_VERSION=10.0
DEFAULT_DOTNET_VERSION=10.0

