# LTS Version Configuration
# This file defines the supported LTS versions for each operating system
# Add or remove versions as needed by editing this file
# Updated 2026-06-29: shifted the support window to current LTS releases.

# Alpine Linux LTS versions (each supported ~2 years from release)
ALPINE_VERSIONS="3.22 3.23 3.24"

# Debian LTS versions
DEBIAN_VERSIONS="12 13"

# RedHat UBI LTS versions
REDHAT_VERSIONS="9 10"

# Default versions (used for platform images and legacy targets) — latest stable
DEFAULT_ALPINE_VERSION=3.24
DEFAULT_DEBIAN_VERSION=13
DEFAULT_REDHAT_VERSION=10

# Version descriptions for documentation
ALPINE_3_22_DESC="Released May 2025, supported until May 2027"
ALPINE_3_23_DESC="Released November 2025, supported until November 2027"
ALPINE_3_24_DESC="Released May 2026, supported until May 2028"

DEBIAN_12_DESC="Bookworm — released June 2023, supported until June 2028"
DEBIAN_13_DESC="Trixie — released August 2025, supported until ~2030"

REDHAT_9_DESC="UBI 9 — released May 2022, supported until May 2032"
REDHAT_10_DESC="UBI 10 — released 2025, supported until ~2035"
